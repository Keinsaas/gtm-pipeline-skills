# GTM Pipeline Skills — Environment Variables
# Copy this file to your preferred location and set GTM_ENV_PATH in skills/_shared/local.md
# (or default: $HOME/.env.gtm)

# --- People & company search / enrichment ---

# Pipe0 — company/people search waterfall (Amplemarket, Crustdata)
#         and email enrichment. Sign up: https://pipe0.com
PIPE0_API_KEY=

# FullEnrich — email waterfall, company finder. Sign up: https://fullenrich.com
FULLENRICH_API_KEY=

# BetterContact — phone enrichment, lead finder. Sign up: https://bettercontact.rocks
BETTERCONTACT_API_KEY=

# --- Research & web ---

# SerpAPI — Google search results, domain lookups. Sign up: https://serpapi.com
SERPAPI_API_KEY=

# Parallel AI — FindAll discovery, Task Groups, web search.
#               Sign up: https://parallel.ai
PARALLEL_API_KEY=

# Apify — SimilarWeb traffic data. Sign up: https://apify.com
APIFY_API_KEY=

# Firecrawl — website scraping, agent-based extraction.
#             Sign up: https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- LinkedIn automation ---

# PhantomBuster — LinkedIn scraping, outreach automation.
#                 Sign up: https://phantombuster.com
PHANTOMBUSTER_API_KEY=

# LinkedIn session (required for PhantomBuster agents that scrape LinkedIn)
# Get LINKEDIN_SESSION_COOKIE from: https://www.linkedin.com cookies → "li_at"
# Get LINKEDIN_USER_AGENT from: https://whatismybrowser.com (your browser's UA string)
LINKEDIN_SESSION_COOKIE=
LINKEDIN_USER_AGENT=

# --- LLM routing ---

# OpenRouter — LLM routing for signal assessment and ICP scoring.
#              Sign up: https://openrouter.ai
OPENROUTER_API_KEY=
